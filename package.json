{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "nuvio-providers",
  "version": "1.1.39",
  "description": "Providers for Nuvio Streaming",
  "scripts": {
    "build": "node build.js",
    "build:minify": "node build.js --minify",
    "build:quickjs": "node build.js --engine quickjs",
    "build:quickjs:minify": "node build.js --engine quickjs --minify",
    "build:watch": "nodemon --watch src -e js,json --exec 'node build.js'",
    "build:provider": "node build.js",
    "validate": "node scripts/local-validate.js",
    "validate:movix": "node scripts/local-validate.js movix",
    "validate:frenchstream": "node scripts/local-validate.js frenchstream",
    "test:movix": "node scripts/test-movix-local.js",
    "test:frenchstream": "node scripts/test-frenchstream-local.js",
    "serve": "node server.js",
    "test:provider": "node scripts/provider-success-runner.js",
    "test:provider:both": "node scripts/provider-success-runner.js --profile both",
    "test:androidtv13": "node scripts/provider-success-runner.js --profile tv --android-tv13",
    "release-check": "node scripts/release-check.js"
  },
  "devDependencies": {
    "cheerio": "^1.1.2",
    "esbuild": "^0.27.3",
    "nodemon": "^3.1.0"
  },
  "keywords": [
    "nuvio",
    "streaming",
    "providers"
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "cheerio-without-node-native": "^0.20.2",
    "crypto-js": "^4.2.0",
    "htmlparser2-without-node-native": "^3.9.2"
  }
}